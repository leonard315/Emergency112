{{> head}}
<body class="bg-[#060b14] min-h-screen">

<!-- Mobile sidebar overlay -->
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<style>
  .nav-item{border-left:3px solid transparent;transition:all .15s}
  .nav-item:hover{background:rgba(255,255,255,.04);color:#fff;border-left-color:rgba(255,255,255,.1)}
  .nav-active{background:linear-gradient(135deg,rgba(220,38,38,.12),rgba(220,38,38,.04));border-left:3px solid #dc2626;color:#fff}
  .stat-card{position:relative;overflow:hidden;transition:all .2s}
  .stat-card::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.03),transparent);pointer-events:none}
  .stat-card:hover{transform:translateY(-2px)}
  .ring-chart{transform:rotate(-90deg)}
</style>

  <!-- Sidebar -->
  <aside class="sidebar-fixed w-64 bg-[#0a1628] border-r border-white/5 flex flex-col fixed h-full z-50 shadow-2xl" id="sidebar">
    <div class="px-5 py-5 border-b border-white/5 flex-shrink-0">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-red-600 rounded-xl flex items-center justify-center pulse-ring shadow-lg shadow-red-900/40 flex-shrink-0">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        </div>
        <div>
          <p class="text-sm font-black text-white leading-none tracking-tight">Emergency Hotline</p>
          <p class="text-xs text-red-400 font-semibold mt-0.5 tracking-wider uppercase">Admin Panel</p>
        </div>
      </div>
    </div>

    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      <p class="text-xs text-slate-700 font-semibold uppercase tracking-widest px-3 mb-2">Main</p>
      <a href="/admin/dashboard" class="nav-item nav-active flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-sm font-semibold">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Dashboard
      </a>
      <a href="/admin/alerts" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        Manage Alerts
      </a>
      <a href="/admin/users" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Manage Users
      </a>
      <p class="text-xs text-slate-700 font-semibold uppercase tracking-widest px-3 mb-2 mt-4">Reports</p>
      <a href="/alerts/history" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Alert History
      </a>
      <a href="/map" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
        Live Map
      </a>
      <a href="/profile" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        My Profile
      </a>
    </nav>

    <div class="px-3 py-3 border-t border-white/5 flex-shrink-0 pb-safe" style="padding-bottom:max(60px,env(safe-area-inset-bottom))">
      <div class="flex items-center gap-2.5 px-2 py-2 mb-1 rounded-xl bg-white/3">
        <div class="w-7 h-7 bg-red-600/20 border border-red-700/40 rounded-full flex items-center justify-center flex-shrink-0">
          <span class="text-xs font-black text-red-400">{{ adminName.[0] }}</span>
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-xs font-bold text-white truncate leading-none">{{ adminName }}</p>
          <p class="text-xs text-red-400 mt-0.5">Administrator</p>
        </div>
      </div>
      <a href="/logout" class="nav-item flex items-center gap-2 px-2 py-2 rounded-xl text-slate-500 hover:text-red-400 hover:bg-red-950/20 text-sm transition">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        Sign Out
      </a>
    </div>
  </aside>

  <!-- Main -->
  <div class="main-content ml-0 flex-1 flex flex-col min-h-screen w-full">

    <!-- Top bar -->
    <header class="bg-[#0a1628]/80 backdrop-blur-xl border-b border-white/5 px-4 lg:px-8 py-4 flex justify-between items-center sticky top-0 z-[500]">
      <div class="flex items-center gap-3">
        <!-- Hamburger for mobile -->
        <button onclick="openSidebar()" style="width:36px;height:36px;min-width:36px;min-height:36px;max-width:36px;max-height:36px;display:flex;align-items:center;justify-content:center;flex-shrink:0;align-self:center;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:12px;color:#94a3b8;cursor:pointer;padding:0;box-sizing:border-box" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#94a3b8'">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <div>
          <h1 class="text-base lg:text-xl font-black text-white tracking-tight">Admin Dashboard</h1>
          <p class="text-xs text-slate-500 mt-0.5 hidden sm:block">Welcome back, {{ adminName }}</p>
        </div>
      </div>
      <div class="flex items-center gap-2 header-actions">
        <a href="/user/dashboard" class="hidden sm:flex items-center gap-2 text-xs font-semibold text-slate-300 hover:text-white bg-white/5 hover:bg-white/10 border border-white/10 px-3 py-2 rounded-xl transition">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          View as User
        </a>
        <div class="flex items-center gap-2 text-xs text-slate-400 bg-green-950/30 border border-green-800/30 px-3 py-1.5 rounded-full">
          <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse inline-block"></span>
          <span class="hidden sm:inline">System Online</span>
        </div>
      </div>
    </header>

    <div class="flex-1 px-4 lg:px-8 py-4 lg:py-6">

      {{#if success_msg}}
      <div class="mb-5 bg-green-950/40 border border-green-700/30 text-green-300 px-4 py-3 rounded-xl text-sm flex items-center gap-2 fade-in">? {{ success_msg }}</div>
      {{/if}}
      {{#if error_msg}}
      <div class="mb-5 bg-red-950/40 border border-red-700/30 text-red-300 px-4 py-3 rounded-xl text-sm flex items-center gap-2 fade-in">?? {{ error_msg }}</div>
      {{/if}}

      <!-- Analytics bar -->
      <div class="flex flex-wrap items-center justify-between gap-3 mb-5">
        {{#if stats.avgResponseTime}}
        <div class="flex items-center gap-2 bg-blue-950/30 border border-blue-800/30 text-blue-300 px-4 py-2 rounded-xl text-sm">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Avg response: <strong class="text-white ml-1">{{ stats.avgResponseTime }} min</strong>
        </div>
        {{/if}}
        {{#if stats.suspiciousCount}}
        <div class="flex items-center gap-2 bg-yellow-950/40 border border-yellow-700/40 text-yellow-300 px-4 py-2 rounded-xl text-sm">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
          ?? <strong class="text-white mx-1">{{ stats.suspiciousCount }}</strong> suspicious alert(s) detected in last 10 min
          <a href="/admin/alerts" class="text-yellow-400 hover:text-yellow-300 underline text-xs ml-1">Review ?</a>
        </div>
        {{/if}}
        <a href="/alerts/export" class="flex items-center gap-1.5 text-xs bg-green-600/20 hover:bg-green-600/30 border border-green-600/30 text-green-400 px-3 py-2 rounded-xl transition font-semibold">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Export CSV
        </a>
      </div>

      <!-- KPI Stats Row -->
      <div class="stats-grid grid grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4 mb-5">

        <div class="stat-card bg-gradient-to-br from-[#0d1b2e] to-[#0a1628] border border-white/5 rounded-2xl p-5 shadow-xl">
          <div class="flex justify-between items-start mb-3">
            <div class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <span class="text-xs text-slate-600 bg-white/3 px-2 py-0.5 rounded-full">Total</span>
          </div>
          <p class="text-3xl font-black text-white mb-1">{{ stats.totalUsers }}</p>
          <p class="text-xs text-slate-500">Registered Users</p>
        </div>

        <div class="stat-card bg-gradient-to-br from-[#0d1b2e] to-[#0a1628] border border-white/5 rounded-2xl p-5 shadow-xl">
          <div class="flex justify-between items-start mb-3">
            <div class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            </div>
            <span class="text-xs text-slate-600 bg-white/3 px-2 py-0.5 rounded-full">All time</span>
          </div>
          <p class="text-3xl font-black text-white mb-1">{{ stats.totalAlerts }}</p>
          <p class="text-xs text-slate-500">Total Alerts</p>
        </div>

        <div class="stat-card bg-gradient-to-br from-red-950/30 to-[#0a1628] border border-red-500/15 rounded-2xl p-5 shadow-xl" style="box-shadow:0 0 30px rgba(239,68,68,.06)">
          <div class="flex justify-between items-start mb-3">
            <div class="w-10 h-10 bg-red-500/10 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            </div>
            <span class="flex items-center gap-1 text-xs text-red-400 bg-red-950/50 px-2 py-0.5 rounded-full">
              <span class="w-1.5 h-1.5 bg-red-500 rounded-full animate-pulse inline-block"></span>Live
            </span>
          </div>
          <p class="text-3xl font-black text-red-400 mb-1">{{ stats.activeAlerts }}</p>
          <p class="text-xs text-slate-500">Active Alerts</p>
        </div>

        <div class="stat-card bg-gradient-to-br from-green-950/20 to-[#0a1628] border border-green-500/10 rounded-2xl p-5 shadow-xl" style="box-shadow:0 0 30px rgba(34,197,94,.04)">
          <div class="flex justify-between items-start mb-3">
            <div class="w-10 h-10 bg-green-500/10 rounded-xl flex items-center justify-center">
              <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <span class="text-xs text-green-600 bg-green-950/50 px-2 py-0.5 rounded-full">Done</span>
          </div>
          <p class="text-3xl font-black text-green-400 mb-1">{{ stats.resolvedAlerts }}</p>
          <p class="text-xs text-slate-500">Resolved Alerts</p>
        </div>

      </div>
      <!-- Agency breakdown + Responding -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-5">
        <div class="bg-[#0d1b2e] border rounded-2xl p-5 flex items-center gap-4 transition hover:border-orange-500/30" style="border-color:rgba(249,115,22,.15)">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background:rgba(249,115,22,.12);border:1px solid rgba(249,115,22,.25)">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/></svg>
          </div>
          <div>
            <p class="text-2xl font-black text-orange-400 leading-none">{{ stats.fireCount }}</p>
            <p class="text-xs font-semibold text-white mt-1">Fire</p>
            <p class="text-xs text-orange-700 mt-0.5">Bureau of Fire Protection</p>
          </div>
        </div>
        <div class="bg-[#0d1b2e] border rounded-2xl p-5 flex items-center gap-4 transition hover:border-blue-500/30" style="border-color:rgba(59,130,246,.15)">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background:rgba(59,130,246,.12);border:1px solid rgba(59,130,246,.25)">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <div>
            <p class="text-2xl font-black text-blue-400 leading-none">{{ stats.crimeCount }}</p>
            <p class="text-xs font-semibold text-white mt-1">Crime</p>
            <p class="text-xs text-blue-700 mt-0.5">Philippine National Police</p>
          </div>
        </div>
        <div class="bg-[#0d1b2e] border rounded-2xl p-5 flex items-center gap-4 transition hover:border-red-500/30" style="border-color:rgba(239,68,68,.15)">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background:rgba(239,68,68,.12);border:1px solid rgba(239,68,68,.25)">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          </div>
          <div>
            <p class="text-2xl font-black text-red-400 leading-none">{{ stats.medicalCount }}</p>
            <p class="text-xs font-semibold text-white mt-1">Medical</p>
            <p class="text-xs text-red-700 mt-0.5">Emergency Medical Services</p>
          </div>
        </div>
        <div class="bg-[#0d1b2e] border rounded-2xl p-5 flex items-center gap-4 transition hover:border-yellow-500/30" style="border-color:rgba(234,179,8,.15)">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0" style="background:rgba(234,179,8,.12);border:1px solid rgba(234,179,8,.25)">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div>
            <p class="text-2xl font-black text-yellow-400 leading-none">{{ stats.respondingAlerts }}</p>
            <p class="text-xs font-semibold text-white mt-1">Responding</p>
            <p class="text-xs text-yellow-700 mt-0.5">Currently Active</p>
          </div>
        </div>
      </div>

      <!-- Map + Panels -->
      <div class="map-grid grid grid-cols-1 lg:grid-cols-3 gap-4">

        <!-- Chart + Live Map stacked -->
        <div class="lg:col-span-2 space-y-4">

          <!-- 7-day chart -->
          <div class="bg-[#0d1b2e] border border-white/5 rounded-2xl p-5">
            <div class="flex justify-between items-center mb-3">
              <h2 class="text-sm font-bold text-white">Alerts � Last 7 Days</h2>
              <span class="text-xs text-slate-600 bg-white/5 px-2.5 py-1 rounded-full">Daily count</span>
            </div>
            <canvas id="alertChart" height="70"></canvas>
          </div>

          <!-- Live Map -->
          <div class="bg-[#0d1b2e] border border-white/5 rounded-2xl overflow-hidden shadow-2xl" style="isolation:isolate;position:relative;z-index:0">
            <div class="px-5 py-4 border-b border-white/5 flex justify-between items-center bg-gradient-to-r from-white/2 to-transparent">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></div>
                <h2 class="text-sm font-bold text-white">Live Emergency Map</h2>
                <span class="text-xs text-slate-600 bg-white/3 px-2 py-0.5 rounded-full" id="mapPinCount">0 pins</span>
              </div>
              <a href="/map" class="flex items-center gap-1.5 text-xs text-red-400 hover:text-red-300 transition font-medium">
                Full map
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
            <div id="adminMap" style="height:320px;width:100%;position:relative;z-index:0"></div>
          </div>
        </div>

        <!-- Right panels -->
        <div class="flex flex-col gap-4">

          <!-- Recent Alerts -->
          <div class="bg-[#0d1b2e] border border-white/5 rounded-2xl overflow-hidden flex-1">
            <div class="px-5 py-3.5 border-b border-white/5 flex justify-between items-center">
              <h2 class="text-sm font-bold text-white flex items-center gap-2">
                <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse inline-block"></span>
                Recent Alerts
              </h2>
              <a href="/admin/alerts" class="flex items-center gap-1 text-xs font-semibold text-red-400 hover:text-red-300 transition">All <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></a>
            </div>
            <div class="divide-y divide-white/5 max-h-52 overflow-y-auto">
              {{#each recentAlerts}}
              <div class="px-4 py-3 flex items-center gap-3 hover:bg-white/3 transition border-l-2 {{#if (eq type 'fire')}}border-orange-500/60{{/if}}{{#if (eq type 'crime')}}border-blue-500/60{{/if}}{{#if (eq type 'medical')}}border-red-500/60{{/if}}{{#if (eq type 'all')}}border-white/20{{/if}}">
                <div class="w-9 h-9 rounded-xl flex items-center justify-center flex-shrink-0 {{#if (eq type 'fire')}}bg-orange-500/15{{/if}}{{#if (eq type 'crime')}}bg-blue-500/15{{/if}}{{#if (eq type 'medical')}}bg-red-500/15{{/if}}{{#if (eq type 'all')}}bg-white/8{{/if}}">
                  {{#if (eq type 'fire')}}<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/></svg>{{/if}}
                  {{#if (eq type 'crime')}}<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>{{/if}}
                  {{#if (eq type 'medical')}}<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>{{/if}}
                  {{#if (eq type 'all')}}<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>{{/if}}
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs font-semibold text-white truncate">{{ label }}</p>
                  <p class="text-xs text-slate-600 truncate mt-0.5">{{ location }}</p>
                  <p class="text-xs text-slate-700 mt-0.5">{{ timeAgo }}</p>
                </div>
                <span class="text-xs px-2 py-0.5 rounded-md font-semibold flex-shrink-0 {{#if (eq status 'active')}}bg-red-500/15 text-red-400{{/if}}{{#if (eq status 'responding')}}bg-yellow-500/15 text-yellow-400{{/if}}{{#if (eq status 'resolved')}}bg-green-500/15 text-green-400{{/if}}">{{ status }}</span>
              </div>
              {{else}}
              <div class="px-4 py-10 text-center">
                <div class="w-10 h-10 bg-white/5 rounded-xl flex items-center justify-center mx-auto mb-3"><svg class="w-5 h-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg></div>
                <p class="text-slate-600 text-xs font-medium">No alerts yet</p>
              </div>
              {{/each}}
            </div>
          </div>

          <!-- Users -->
          <div class="bg-[#0d1b2e] border border-white/5 rounded-2xl overflow-hidden">
            <div class="px-5 py-3.5 border-b border-white/5 flex justify-between items-center">
              <h2 class="text-sm font-bold text-white flex items-center gap-2">
                <svg class="w-3.5 h-3.5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Registered Users
              </h2>
              <a href="/admin/users" class="flex items-center gap-1 text-xs font-semibold text-red-400 hover:text-red-300 transition">Manage <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></a>
            </div>
            <div class="divide-y divide-white/5 max-h-44 overflow-y-auto">
              {{#each users}}
              <div class="px-4 py-3 flex items-center justify-between gap-3 hover:bg-white/3 transition">
                <div class="flex items-center gap-3 min-w-0">
                  <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0 text-xs font-black {{#if (eq role 'admin')}}bg-red-600 text-white shadow-lg shadow-red-900/40{{else}}bg-white/10 text-slate-300{{/if}}">{{ name.[0] }}</div>
                  <div class="min-w-0">
                    <p class="text-xs font-semibold text-white truncate">{{ name }}</p>
                    <p class="text-xs text-slate-600 truncate">{{ email }}</p>
                  </div>
                </div>
                <span class="text-xs px-2 py-0.5 rounded-md font-semibold flex-shrink-0 {{#if (eq role 'admin')}}bg-red-500/15 text-red-400{{else}}bg-white/5 text-slate-500{{/if}}">{{ role }}</span>
              </div>
              {{else}}
              <div class="px-4 py-6 text-center text-slate-600 text-xs">No users yet.</div>
              {{/each}}
            </div>
          </div>
        </div>
      </div>
    </div>

    {{> footer}}
  </div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  .leaflet-popup-content-wrapper{background:#0d1b2e!important;border:1px solid rgba(255,255,255,.08)!important;border-radius:14px!important;color:#e2e8f0!important;box-shadow:0 20px 60px rgba(0,0,0,.7)!important;padding:0!important}
  .leaflet-popup-content{margin:0!important}
  .leaflet-popup-tip-container{display:none}
  .leaflet-popup-close-button{color:#475569!important;top:8px!important;right:10px!important}
  .leaflet-control-zoom a{background:#0d1b2e!important;color:#64748b!important;border-color:rgba(255,255,255,.08)!important}
  .leaflet-control-zoom a:hover{background:#1e293b!important;color:#fff!important}
  .leaflet-bar{border:1px solid rgba(255,255,255,.08)!important;border-radius:10px!important;overflow:hidden}
  /* Keep Leaflet tiles inside the map container */
  #adminMap .leaflet-pane { z-index: 1 !important; }
  #adminMap .leaflet-tile-pane { z-index: 1 !important; }
  #adminMap .leaflet-overlay-pane { z-index: 2 !important; }
  #adminMap .leaflet-marker-pane { z-index: 3 !important; }
  #adminMap .leaflet-popup-pane { z-index: 4 !important; }
  #adminMap .leaflet-control { z-index: 5 !important; }
</style>
<script>
  const aMap=L.map('adminMap',{zoomControl:true,attributionControl:false}).setView([12.8797,121.7740],6);
  L.tileLayer('https://{s}.google.com/vt/lyrs=m&x={x}&y={y}&z={z}',{subdomains:['mt0','mt1','mt2','mt3'],maxZoom:20}).addTo(aMap);
  // Invalidate size multiple times to ensure correct render
  setTimeout(function(){ aMap.invalidateSize(); }, 100);
  setTimeout(function(){ aMap.invalidateSize(); }, 500);
  setTimeout(function(){ aMap.invalidateSize(); }, 1000);
  let aM=[];
  const aColors={fire:'#f97316',crime:'#3b82f6',medical:'#ef4444',all:'#e2e8f0'};
  const aS={active:'#f87171',responding:'#fbbf24',resolved:'#4ade80'};
  function loadAMap(){
    fetch('/api/alerts').then(r=>r.json()).then(alerts=>{
      aM.forEach(m=>aMap.removeLayer(m));aM=[];
      const pinned=alerts.filter(a=>a.latitude&&a.longitude);
      document.getElementById('mapPinCount').textContent=pinned.length+' pin'+(pinned.length!==1?'s':'');
      pinned.forEach(a=>{
        const color=aColors[a.type]||'#ef4444';
        const active=a.status==='active';
        const size=active?44:36;
        const labels={fire:'F',crime:'C',medical:'M',all:'A'};
        const html=`<div style="position:relative;width:${size}px;height:${size+12}px">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 56" width="${size}" height="${size+12}" style="position:absolute;top:0;left:0;filter:drop-shadow(0 4px 12px rgba(0,0,0,.6))">
            <path d="M20 0C8.954 0 0 8.954 0 20c0 15 20 36 20 36S40 35 40 20C40 8.954 31.046 0 20 0z" fill="${color}" stroke="white" stroke-width="2"/>
            <circle cx="20" cy="20" r="9" fill="white" opacity="0.95"/>
            <text x="20" y="24" text-anchor="middle" font-size="10" font-weight="bold" fill="${color}">${labels[a.type]||'!'}</text>
          </svg>
        </div>`;
        const icon=L.divIcon({className:'',html,iconSize:[size,size+12],iconAnchor:[size/2,size+12],popupAnchor:[0,-(size+16)]});
        const sc=aS[a.status]||'#94a3b8';
        const m=L.marker([a.latitude,a.longitude],{icon});
        m.bindPopup(`<div style="padding:14px 16px;min-width:200px">
          <strong style="font-size:13px;color:#f1f5f9">${a.label}</strong>
          <p style="font-size:11px;color:#64748b;margin:4px 0">?? ${a.location||'Unknown'}</p>
          <p style="font-size:11px;color:#64748b;margin:3px 0">?? ${a.reportedBy||''}</p>
          <span style="display:inline-block;margin-top:8px;font-size:10px;padding:3px 10px;border-radius:999px;background:${sc}18;border:1px solid ${sc}50;color:${sc};font-weight:700">${a.status.toUpperCase()}</span>
        </div>`);
        m.addTo(aMap);aM.push(m);
      });
      if(aM.length>0)aMap.fitBounds(L.featureGroup(aM).getBounds().pad(0.3));
    });
  }
  loadAMap();
  setInterval(loadAMap,10000);
</script>
<script>
  // 7-day chart
  // Init chart � wait for Chart.js to be ready
  function initChart() {
    const ctx = document.getElementById('alertChart');
    if (!ctx) return;
    if (typeof Chart === 'undefined') { setTimeout(initChart, 100); return; }
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: {{{ chartLabels }}},
        datasets: [{
          label: 'Alerts',
          data: {{{ chartData }}},
          backgroundColor: 'rgba(220,38,38,.45)',
          borderColor: '#dc2626',
          borderWidth: 2,
          borderRadius: 6,
          borderSkipped: false
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: { legend: { display: false } },
        scales: {
          x: {
            grid: { color: 'rgba(255,255,255,.04)' },
            ticks: { color: '#475569', font: { size: 11 } },
            border: { color: 'rgba(255,255,255,.06)' }
          },
          y: {
            grid: { color: 'rgba(255,255,255,.04)' },
            ticks: { color: '#475569', font: { size: 11 }, stepSize: 1 },
            border: { color: 'rgba(255,255,255,.06)' },
            beginAtZero: true
          }
        }
      }
    });
  }
  initChart();

  // Live tab count
  function updateTabCount() {
    fetch('/api/alerts').then(r=>r.json()).then(data=>{
      const active = data.filter(a=>a.status==='active').length;
      document.title = active > 0 ? `(${active}) Admin Dashboard � Emergency Hotline` : 'Admin Dashboard � Emergency Hotline';
    }).catch(()=>{});
  }
  updateTabCount();
  setInterval(updateTabCount, 15000);
</script>
<script>
  function openSidebar(){
    document.getElementById('sidebar').classList.add('open');
    document.getElementById('sidebarOverlay').classList.add('open');
    document.body.style.overflow='hidden';
  }
  function closeSidebar(){
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarOverlay').classList.remove('open');
    document.body.style.overflow='';
  }
  function navTo(e,url){ e.preventDefault(); closeSidebar(); setTimeout(()=>{ window.location.href=url; },220); }

  // Attach sidebar link interceptor directly � script is at bottom so DOM is ready
  (function() {
    var sb = document.getElementById('sidebar');
    if (!sb) return;
    sb.addEventListener('click', function(e) {
      var link = e.target.closest('a[href]');
      if (!link) return;
      var href = link.getAttribute('href');
      if (href === '/logout') return;
      e.preventDefault();
      sb.classList.remove('open');
      document.getElementById('sidebarOverlay').classList.remove('open');
      document.body.style.overflow = '';
      setTimeout(function() { window.location.href = href; }, 200);
    });
  })();
</script>


