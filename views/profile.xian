{{> head}}
<body class="bg-[#060b14] min-h-screen">

<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<style>
  .input-field { width:100%; background:rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.1); color:#f1f5f9; border-radius:12px; padding:10px 14px; font-size:14px; outline:none; transition:all .15s; }
  .input-field:focus { border-color:rgba(220,38,38,.4); box-shadow:0 0 0 3px rgba(220,38,38,.08); }
  .hotline-card { display:flex; flex-direction:column; align-items:center; gap:10px; border-radius:16px; padding:18px 12px; border:1px solid; transition:all .2s; text-decoration:none; }
  .hotline-card:hover { transform:translateY(-2px); }
</style>


  <!-- -- SIDEBAR -- -->
  <aside class="sidebar-fixed w-64 bg-[#080f1e] border-r border-white/5 flex flex-col fixed h-full z-50 shadow-2xl" id="sidebar">
    <div class="px-5 py-5 border-b border-white/5 flex-shrink-0">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-red-600 rounded-xl flex items-center justify-center flex-shrink-0 pulse-ring shadow-lg shadow-red-900/40">
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        </div>
        <div>
          <p class="text-sm font-black text-white leading-none">Emergency Hotline</p>
          <p class="text-xs text-slate-500 mt-0.5">My Profile</p>
        </div>
      </div>
    </div>
    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      {{#if isUser}}
      <!-- User nav -->
      <a href="/user/dashboard" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Home
      </a>
      <a href="/alerts/history" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        My Reports
      </a>
      <a href="/map" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
        Live Map
      </a>
      <a href="/profile" class="nav-item nav-active flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-sm font-semibold">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        My Profile
      </a>
      {{else}}
      <!-- Admin / Agency nav -->
      <p class="text-xs text-slate-700 font-semibold uppercase tracking-widest px-3 mb-2">Main</p>
      <a href="{{ dashboardLink }}" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Dashboard
      </a>
      <p class="text-xs text-slate-700 font-semibold uppercase tracking-widest px-3 mb-2 mt-4">Reports</p>
      <a href="/alerts/history" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Alert History
      </a>
      <a href="/map" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
        Live Map
      </a>
      <a href="/profile" class="nav-item nav-active flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-sm font-semibold">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        My Profile
      </a>
      {{/if}}
    </nav>
    <div class="px-3 py-3 border-t border-white/5 flex-shrink-0" style="padding-bottom:max(60px,env(safe-area-inset-bottom))">
      <a href="/logout" class="nav-item flex items-center gap-2 px-3 py-2 rounded-xl text-slate-500 hover:text-red-400 hover:bg-red-950/20 text-sm transition">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        Sign Out
      </a>
    </div>
  </aside>

  <!-- -- MAIN -- -->
  <div class="main-content ml-0 flex-1 flex flex-col min-h-screen">

    <!-- Header -->
    <header class="bg-[#080f1e]/90 backdrop-blur-xl border-b border-white/5 px-4 lg:px-6 py-3.5 sticky top-0 z-20 flex items-center gap-3">
      <button onclick="openSidebar()" style="width:36px;height:36px;min-width:36px;min-height:36px;max-width:36px;max-height:36px;display:flex;align-items:center;justify-content:center;flex-shrink:0;align-self:center;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:12px;color:#94a3b8;cursor:pointer;padding:0;box-sizing:border-box" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#94a3b8'">
        <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
      <div>
        <h1 class="text-base font-black text-white leading-none">My Profile</h1>
        <p class="text-xs text-slate-500 mt-0.5 hidden sm:block">Manage your account settings</p>
      </div>
    </header>

    <div class="flex-1 px-4 lg:px-6 py-5 pb-24 lg:pb-6 max-w-2xl w-full mx-auto">

      <!-- Flash -->
      {{#if success_msg}}
      <div class="mb-5 bg-green-950/50 border border-green-700/40 text-green-300 px-4 py-3 rounded-xl text-sm flex items-center gap-2 fade-in">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
        {{ success_msg }}
      </div>
      {{/if}}
      {{#if error_msg}}
      <div class="mb-5 bg-red-950/50 border border-red-700/40 text-red-300 px-4 py-3 rounded-xl text-sm flex items-center gap-2 fade-in">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        {{ error_msg }}
      </div>
      {{/if}}

      <!-- -- PROFILE CARD -- -->
      <div class="bg-[#0d1b2e] border border-white/6 rounded-2xl p-6 mb-4 shadow-xl">
        <div class="flex items-center gap-4 mb-5 pb-5 border-b border-white/5">
          <!-- Avatar -->
          <div class="w-16 h-16 rounded-2xl flex items-center justify-center flex-shrink-0 text-2xl font-black border
            {{#if (eq user.role 'admin')}}bg-red-600/20 border-red-700/30 text-red-400{{/if}}
            {{#if (eq user.role 'user')}}bg-white/8 border-white/12 text-slate-300{{/if}}
            {{#if (eq user.role 'bfp')}}bg-orange-500/15 border-orange-500/25 text-orange-400{{/if}}
            {{#if (eq user.role 'pnp')}}bg-blue-500/15 border-blue-500/25 text-blue-400{{/if}}
            {{#if (eq user.role 'ems')}}bg-red-500/15 border-red-500/25 text-red-400{{/if}}">
            {{ user.name.[0] }}
          </div>
          <!-- Info -->
          <div class="flex-1 min-w-0">
            <h2 class="text-lg font-black text-white leading-none truncate">{{ user.name }}</h2>
            <p class="text-sm text-slate-400 mt-0.5 truncate">{{ user.email }}</p>
            <div class="flex flex-wrap items-center gap-2 mt-2">
              <span class="text-xs px-2.5 py-0.5 rounded-full font-bold border
                {{#if (eq user.role 'admin')}}bg-red-950/60 text-red-400 border-red-800/50{{/if}}
                {{#if (eq user.role 'user')}}bg-white/5 text-slate-400 border-white/10{{/if}}
                {{#if (eq user.role 'bfp')}}bg-orange-500/10 text-orange-400 border-orange-500/20{{/if}}
                {{#if (eq user.role 'pnp')}}bg-blue-500/10 text-blue-400 border-blue-500/20{{/if}}
                {{#if (eq user.role 'ems')}}bg-red-500/10 text-red-400 border-red-500/20{{/if}}">
                {{ user.role }}
              </span>
              {{#if user.isSuspended}}
              <span class="text-xs px-2.5 py-0.5 rounded-full font-bold bg-red-500/15 text-red-400 border border-red-500/30">? Suspended</span>
              {{/if}}
              {{#if user.falseReportCount}}
              <span class="text-xs px-2.5 py-0.5 rounded-full font-semibold bg-yellow-500/10 text-yellow-400 border border-yellow-500/20">{{ user.falseReportCount }}/3 warnings</span>
              {{/if}}
            </div>
          </div>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-3">
          <div class="bg-white/3 border border-white/6 rounded-xl p-3 text-center">
            <p class="text-2xl font-black text-white leading-none">{{ totalAlerts }}</p>
            <p class="text-xs text-slate-500 mt-1">Total Reports</p>
          </div>
          <div class="bg-red-500/5 border border-red-500/15 rounded-xl p-3 text-center">
            <p class="text-2xl font-black text-red-400 leading-none">{{ activeAlerts }}</p>
            <p class="text-xs text-slate-500 mt-1">Active</p>
          </div>
          <div class="bg-green-500/5 border border-green-500/15 rounded-xl p-3 text-center">
            <p class="text-2xl font-black text-green-400 leading-none">{{ resolvedAlerts }}</p>
            <p class="text-xs text-slate-500 mt-1">Resolved</p>
          </div>
        </div>
      </div>

      <!-- -- EDIT PROFILE -- -->
      <div class="bg-[#0d1b2e] border border-white/6 rounded-2xl p-6 mb-4 shadow-xl">
        <div class="flex items-center gap-2.5 mb-5">
          <div class="w-8 h-8 bg-red-500/10 border border-red-500/20 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          </div>
          <div>
            <p class="text-sm font-bold text-white leading-none">Edit Profile</p>
            <p class="text-xs text-slate-500 mt-0.5">Update your name and email</p>
          </div>
        </div>
        <form method="POST" action="/profile/update" class="space-y-4">
          <div>
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Full Name</label>
            <input type="text" name="name" value="{{ user.name }}" required class="input-field"/>
          </div>
          <div>
            <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-1.5">Email Address</label>
            <input type="email" name="email" value="{{ user.email }}" required class="input-field"/>
          </div>
          <button type="submit"
            class="flex items-center gap-2 bg-red-600 hover:bg-red-500 text-white font-bold px-6 py-2.5 rounded-xl text-sm transition"
            style="box-shadow:0 4px 16px rgba(220,38,38,.3)">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            Save Changes
          </button>
        </form>
      </div>

      <!-- -- EMERGENCY HOTLINES -- -->
      <div class="bg-[#0d1b2e] border border-white/6 rounded-2xl p-6 shadow-xl">
        <div class="flex items-center gap-2.5 mb-5">
          <div class="w-8 h-8 bg-white/5 border border-white/10 rounded-xl flex items-center justify-center flex-shrink-0">
            <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          </div>
          <div>
            <p class="text-sm font-bold text-white leading-none">Emergency Hotlines</p>
            <p class="text-xs text-slate-500 mt-0.5">Tap to call directly</p>
          </div>
        </div>
        <div class="grid grid-cols-3 gap-3">
          <a href="tel:911" class="hotline-card bg-orange-500/8 border-orange-500/20 hover:bg-orange-500/15">
            <div class="w-12 h-12 bg-orange-500/15 border border-orange-500/25 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="#f97316" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/></svg>
            </div>
            <p class="text-xs font-black text-white">BFP</p>
            <p class="text-sm font-black text-orange-400">911</p>
          </a>
          <a href="tel:117" class="hotline-card bg-blue-500/8 border-blue-500/20 hover:bg-blue-500/15">
            <div class="w-12 h-12 bg-blue-500/15 border border-blue-500/25 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="#3b82f6" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <p class="text-xs font-black text-white">PNP</p>
            <p class="text-sm font-black text-blue-400">117</p>
          </a>
          <a href="tel:911" class="hotline-card bg-red-500/8 border-red-500/20 hover:bg-red-500/15">
            <div class="w-12 h-12 bg-red-500/15 border border-red-500/25 rounded-xl flex items-center justify-center">
              <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="#ef4444" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
            </div>
            <p class="text-xs font-black text-white">EMS</p>
            <p class="text-sm font-black text-red-400">911</p>
          </a>
        </div>
      </div>

    </div>

    <footer class="hidden lg:flex items-center justify-between px-6 py-4 border-t border-white/5 text-xs text-slate-700">
      <span>Emergency Hotline � My Profile</span>
      <span>&copy; 2026 � Mindoro State University</span>
    </footer>
  </div>

{{> footer}}

<script>
function openSidebar(){ document.getElementById('sidebar').classList.add('open'); document.getElementById('sidebarOverlay').classList.add('open'); document.body.style.overflow='hidden'; }
function closeSidebar(){ document.getElementById('sidebar').classList.remove('open'); document.getElementById('sidebarOverlay').classList.remove('open'); document.body.style.overflow=''; }

(function(){
  var sb = document.getElementById('sidebar');
  if(!sb) return;
  sb.addEventListener('click', function(e){
    var link = e.target.closest('a[href]');
    if(!link) return;
    var href = link.getAttribute('href');
    if(href==='/logout') return;
    e.preventDefault();
    sb.classList.remove('open');
    document.getElementById('sidebarOverlay').classList.remove('open');
    document.body.style.overflow='';
    setTimeout(function(){ window.location.href=href; },200);
  });
})();
</script>

</body>
</html>


