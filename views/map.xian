{{> head}}
<body class="bg-[#060b14] min-h-screen">

<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

<style>
  .map-pill { background:rgba(10,22,40,.9); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,.12); color:#94a3b8; transition:all .15s; }
  .map-pill:hover { background:rgba(30,41,59,.95); color:#fff; }
  .map-pill.active { background:#dc2626; border-color:#dc2626; color:#fff; box-shadow:0 0 16px rgba(220,38,38,.4); }
  .tile-btn { background:rgba(10,22,40,.9); backdrop-filter:blur(8px); border:1px solid rgba(255,255,255,.1); color:#94a3b8; transition:all .15s; }
  .tile-btn:hover { background:rgba(30,41,59,.95); color:#fff; }
  .tile-btn.active { background:rgba(30,41,59,.95); border-color:rgba(255,255,255,.25); color:#fff; }
  .stat-card { background:#0d1b2e; border:1px solid rgba(255,255,255,.06); border-radius:14px; padding:14px 16px; display:flex; align-items:center; gap:12px; }
  .alert-item { padding:12px 16px; border-bottom:1px solid rgba(255,255,255,.05); cursor:pointer; transition:background .15s; }
  .alert-item:hover { background:rgba(255,255,255,.04); }
  @keyframes rp { 0%{transform:translateX(-50%) scale(1);opacity:.3} 100%{transform:translateX(-50%) scale(2.2);opacity:0} }
</style>


  <!-- -- SIDEBAR -- -->
  <aside class="sidebar-fixed w-64 bg-[#080f1e] border-r border-white/5 flex flex-col fixed h-full z-50 shadow-2xl" id="sidebar">
    <div class="px-5 py-5 border-b border-white/5 flex-shrink-0">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 bg-red-600 rounded-xl flex items-center justify-center flex-shrink-0 pulse-ring shadow-lg shadow-red-900/40">
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
        </div>
        <div>
          <p class="text-sm font-black text-white leading-none">Emergency Hotline</p>
          <p class="text-xs text-slate-500 mt-0.5">Live Map</p>
        </div>
      </div>
    </div>
    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
      {{#if isUser}}
      <!-- User nav -->
      <a href="/user/dashboard" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Home
      </a>
      <a href="/alerts/history" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        My Reports
      </a>
      <a href="/map" class="nav-item nav-active flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-sm font-semibold">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
        Live Map
      </a>
      <a href="/profile" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        My Profile
      </a>
      {{else}}
      <!-- Admin / Agency nav -->
      <p class="text-xs text-slate-700 font-semibold uppercase tracking-widest px-3 mb-2">Main</p>
      <a href="{{ dashboardLink }}" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Dashboard
      </a>
      <p class="text-xs text-slate-700 font-semibold uppercase tracking-widest px-3 mb-2 mt-4">Reports</p>
      <a href="/alerts/history" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Alert History
      </a>
      <a href="/map" class="nav-item nav-active flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-sm font-semibold">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
        Live Map
      </a>
      <a href="/profile" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        My Profile
      </a>
      {{/if}}
    </nav>
    <div class="px-3 py-3 border-t border-white/5 flex-shrink-0" style="padding-bottom:max(60px,env(safe-area-inset-bottom))">
      <a href="/logout" class="nav-item flex items-center gap-2 px-3 py-2 rounded-xl text-slate-500 hover:text-red-400 hover:bg-red-950/20 text-sm transition">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        Sign Out
      </a>
    </div>
  </aside>

  <!-- -- MAIN -- -->
  <div class="main-content ml-0 flex-1 flex flex-col" style="height:100vh;overflow:hidden">

    <!-- Header -->
    <header class="bg-[#080f1e]/90 backdrop-blur-xl border-b border-white/5 px-4 lg:px-6 py-3.5 sticky top-0 z-[1500] flex items-center justify-between">
      <div class="flex items-center gap-3">
        <button onclick="openSidebar()" style="width:36px;height:36px;min-width:36px;min-height:36px;max-width:36px;max-height:36px;display:flex;align-items:center;justify-content:center;flex-shrink:0;align-self:center;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:12px;color:#94a3b8;cursor:pointer;padding:0;box-sizing:border-box" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#94a3b8'">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <div>
          <h1 class="text-base font-black text-white leading-none">Live Emergency Map</h1>
          <p class="text-xs text-slate-500 mt-0.5 hidden sm:block">Real-time incident locations</p>
        </div>
      </div>
      <!-- Live indicator -->
      <div class="flex items-center gap-2 text-xs font-semibold px-3 py-1.5 rounded-full bg-green-500/10 border border-green-500/20 text-green-400">
        <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse inline-block"></span>
        <span id="mapUpdated" class="hidden sm:inline">Live</span>
      </div>
    </header>

    <!-- Stat strip -->
    <div class="px-4 lg:px-6 pt-4 pb-0 grid grid-cols-2 sm:grid-cols-4 gap-3 flex-shrink-0">
      <div class="stat-card">
        <div class="w-9 h-9 bg-white/5 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
        </div>
        <div><p class="text-xl font-black text-white leading-none" id="statTotal">�</p><p class="text-xs text-slate-500 mt-0.5">Total Pins</p></div>
      </div>
      <div class="stat-card" style="border-color:rgba(249,115,22,.15);background:rgba(249,115,22,.05)">
        <div class="w-9 h-9 bg-orange-500/10 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="#f97316" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/></svg>
        </div>
        <div><p class="text-xl font-black text-orange-400 leading-none" id="statFire">�</p><p class="text-xs text-slate-500 mt-0.5">Fire</p></div>
      </div>
      <div class="stat-card" style="border-color:rgba(59,130,246,.15);background:rgba(59,130,246,.05)">
        <div class="w-9 h-9 bg-blue-500/10 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="#3b82f6" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        </div>
        <div><p class="text-xl font-black text-blue-400 leading-none" id="statCrime">�</p><p class="text-xs text-slate-500 mt-0.5">Crime</p></div>
      </div>
      <div class="stat-card" style="border-color:rgba(239,68,68,.15);background:rgba(239,68,68,.05)">
        <div class="w-9 h-9 bg-red-500/10 rounded-xl flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="#ef4444" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
        </div>
        <div><p class="text-xl font-black text-red-400 leading-none" id="statMedical">�</p><p class="text-xs text-slate-500 mt-0.5">Medical</p></div>
      </div>
    </div>

    <!-- Map + Feed -->
    <div class="flex gap-4 flex-1 p-4 lg:p-6" style="height:calc(100vh - 200px);min-height:480px">

      <!-- Map -->
      <div class="flex-1 rounded-2xl overflow-hidden border border-white/6 relative shadow-2xl" style="isolation:isolate">

        <!-- Filter pills -->
        <div class="absolute top-3 left-3 z-[1000] flex gap-1.5 flex-wrap">
          <button onclick="filterMap('all')"     id="btn-all"     class="map-pill text-xs px-3 py-1.5 rounded-full font-bold">All</button>
          <button onclick="filterMap('fire')"    id="btn-fire"    class="map-pill text-xs px-3 py-1.5 rounded-full font-semibold">?? Fire</button>
          <button onclick="filterMap('crime')"   id="btn-crime"   class="map-pill text-xs px-3 py-1.5 rounded-full font-semibold">?? Crime</button>
          <button onclick="filterMap('medical')" id="btn-medical" class="map-pill text-xs px-3 py-1.5 rounded-full font-semibold">?? Medical</button>
        </div>

        <!-- Tile selector -->
        <div class="absolute bottom-3 left-3 z-[1000] flex gap-1.5">
          <button onclick="setTile('street')"    id="tile-street"    class="tile-btn active text-xs px-3 py-1.5 rounded-lg font-medium">Street</button>
          <button onclick="setTile('satellite')" id="tile-satellite" class="tile-btn text-xs px-3 py-1.5 rounded-lg font-medium">Satellite</button>
          <button onclick="setTile('dark')"      id="tile-dark"      class="tile-btn text-xs px-3 py-1.5 rounded-lg font-medium">Dark</button>
          <button onclick="toggleHeatmap()"      id="btn-heat"       class="tile-btn text-xs px-3 py-1.5 rounded-lg font-medium">Heatmap</button>
        </div>

        <div id="map" style="width:100%;height:100%"></div>
      </div>

      <!-- Alert feed panel -->
      <div class="w-72 bg-[#0d1b2e] border border-white/6 rounded-2xl flex flex-col overflow-hidden shadow-xl hidden lg:flex">
        <div class="px-4 py-3.5 border-b border-white/5 flex items-center justify-between flex-shrink-0">
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse inline-block"></span>
            <h3 class="text-sm font-bold text-white">Alert Feed</h3>
          </div>
          <span class="text-xs text-slate-500 bg-white/5 px-2.5 py-0.5 rounded-full border border-white/8" id="alertCount">0</span>
        </div>
        <div id="alertList" class="flex-1 overflow-y-auto">
          <div class="px-4 py-10 text-center">
            <div class="w-10 h-10 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-3">
              <svg class="w-5 h-5 text-slate-600 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg>
            </div>
            <p class="text-slate-500 text-xs">Loading alerts...</p>
          </div>
        </div>
      </div>

    </div>
  </div>

<!-- Popup styles -->
<style>
  .leaflet-popup-content-wrapper { background:#0d1b2e!important; border:1px solid rgba(255,255,255,.1)!important; border-radius:14px!important; color:#e2e8f0!important; box-shadow:0 20px 60px rgba(0,0,0,.7)!important; padding:0!important; }
  .leaflet-popup-content { margin:0!important; }
  .leaflet-popup-tip-container { display:none; }
  .leaflet-popup-close-button { color:#64748b!important; top:10px!important; right:12px!important; font-size:18px!important; }
  .map-popup { padding:14px 16px; min-width:210px; }
  .map-popup-title { font-size:13px; font-weight:700; color:#f1f5f9; margin-bottom:8px; display:flex; align-items:center; gap:7px; }
  .map-popup-row { font-size:11px; color:#64748b; margin:4px 0; display:flex; align-items:flex-start; gap:5px; }
  .map-popup-badge { display:inline-block; font-size:10px; padding:2px 9px; border-radius:999px; font-weight:600; margin-top:8px; border:1px solid; }
</style>

<script>
  // -- Tile layers ------------------------------------------
  const tiles = {
    street:    L.tileLayer('https://{s}.google.com/vt/lyrs=m&x={x}&y={y}&z={z}',{subdomains:['mt0','mt1','mt2','mt3'],maxZoom:20}),
    satellite: L.tileLayer('https://{s}.google.com/vt/lyrs=s,h&x={x}&y={y}&z={z}',{subdomains:['mt0','mt1','mt2','mt3'],maxZoom:20}),
    dark:      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{subdomains:'abcd',maxZoom:20})
  };

  const map = L.map('map',{zoomControl:false}).setView([12.8797,121.7740],6);
  L.control.zoom({position:'bottomright'}).addTo(map);
  tiles.street.addTo(map);
  let currentTile = 'street';
  // Force correct size after layout renders
  setTimeout(function(){ map.invalidateSize(); }, 100);
  setTimeout(function(){ map.invalidateSize(); }, 500);
  setTimeout(function(){ map.invalidateSize(); }, 1200);

  function setTile(name){
    map.removeLayer(tiles[currentTile]);
    tiles[name].addTo(map);
    currentTile = name;
    document.querySelectorAll('.tile-btn').forEach(b=>b.classList.remove('active'));
    document.getElementById('tile-'+name).classList.add('active');
  }

  // -- Markers ----------------------------------------------
  let allAlerts=[], markers=[], activeFilter='all';
  const cfg = {
    fire:    { e:'??', c:'#f97316' },
    crime:   { e:'??', c:'#3b82f6' },
    medical: { e:'??', c:'#ef4444' },
    all:     { e:'??', c:'#e2e8f0' }
  };
  const statusColors = { active:'#f87171', responding:'#fbbf24', resolved:'#4ade80' };

  function makeMarker(a){
    const color = cfg[a.type]?.c || '#ef4444';
    const isActive = a.status === 'active';
    const emoji = cfg[a.type]?.e || '??';
    const size = isActive ? 44 : 36;
    const html = `
      <div style="position:relative;width:${size}px;height:${size+12}px">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 56" width="${size}" height="${size+12}"
          style="position:absolute;top:0;left:0;filter:drop-shadow(0 4px 8px rgba(0,0,0,.5))${isActive?` drop-shadow(0 0 8px ${color})`:''}">
          <path d="M20 0C8.954 0 0 8.954 0 20c0 15 20 36 20 36S40 35 40 20C40 8.954 31.046 0 20 0z"
            fill="${color}" stroke="white" stroke-width="2"/>
          <circle cx="20" cy="20" r="9" fill="white" opacity="0.95"/>
        </svg>
        <div style="position:absolute;top:${Math.round(size*.18)}px;left:0;width:${size}px;text-align:center;font-size:${Math.round(size*.38)}px;line-height:1">${emoji}</div>
        ${isActive?`<div style="position:absolute;bottom:-4px;left:50%;transform:translateX(-50%);width:${size+8}px;height:${size+8}px;border-radius:50%;background:${color};opacity:.2;animation:rp 1.5s infinite"></div>`:''}
      </div>`;
    return L.divIcon({ className:'', html, iconSize:[size,size+12], iconAnchor:[size/2,size+12], popupAnchor:[0,-(size+16)] });
  }

  function popupHtml(a){
    const sc = statusColors[a.status] || '#94a3b8';
    const c = cfg[a.type] || cfg.medical;
    return `<div class="map-popup">
      <div class="map-popup-title"><span>${c.e}</span>${a.label}</div>
      <div class="map-popup-row"><span>??</span><span>${a.location||'Unknown location'}</span></div>
      <div class="map-popup-row"><span>??</span><span>${a.reportedBy||'Anonymous'}</span></div>
      ${a.notes?`<div class="map-popup-row"><span>??</span><span style="font-style:italic">${a.notes}</span></div>`:''}
      <div class="map-popup-row"><span>??</span><span>${new Date(a.createdAt).toLocaleString()}</span></div>
      <span class="map-popup-badge" style="color:${sc};border-color:${sc};background:${sc}18">${a.status.toUpperCase()}</span>
    </div>`;
  }

  function renderMarkers(alerts){
    markers.forEach(m=>map.removeLayer(m)); markers=[];
    const f = activeFilter==='all' ? alerts : alerts.filter(a=>a.type===activeFilter);
    f.forEach(a=>{
      if(!a.latitude||!a.longitude) return;
      const m = L.marker([a.latitude,a.longitude],{icon:makeMarker(a)});
      m.bindPopup(popupHtml(a),{maxWidth:260});
      m.addTo(map); markers.push(m);
    });
    if(markers.length>0) map.fitBounds(L.featureGroup(markers).getBounds().pad(0.35));
  }

  function renderList(alerts){
    const list = document.getElementById('alertList');
    const f = activeFilter==='all' ? alerts : alerts.filter(a=>a.type===activeFilter);
    document.getElementById('alertCount').textContent = f.length;
    if(!f.length){
      list.innerHTML=`<div class="px-4 py-10 text-center">
        <div class="w-10 h-10 bg-white/5 rounded-2xl flex items-center justify-center mx-auto mb-3">
          <svg class="w-5 h-5 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <p class="text-slate-400 text-sm font-semibold">All Clear</p>
        <p class="text-slate-600 text-xs mt-1">No alerts to show</p>
      </div>`;
      return;
    }
    list.innerHTML = f.map(a=>{
      const c = cfg[a.type] || cfg.medical;
      const sc = {
        active:    'text-red-400 border-red-800/50 bg-red-950/30',
        responding:'text-yellow-400 border-yellow-800/50 bg-yellow-950/30',
        resolved:  'text-green-400 border-green-800/50 bg-green-950/30'
      }[a.status] || '';
      const hasCoords = a.latitude && a.longitude;
      return `<div class="alert-item" onclick="${hasCoords?`map.setView([${a.latitude},${a.longitude}],16);`:''}">
        <div class="flex items-start justify-between gap-2">
          <div class="flex items-start gap-2.5">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center text-sm flex-shrink-0"
              style="background:${c.c}18;border:1px solid ${c.c}30">${c.e}</div>
            <div class="min-w-0">
              <p class="text-xs font-bold text-white leading-none">${a.label}</p>
              <p class="text-xs text-slate-500 mt-0.5 truncate">${a.location||'No location'}</p>
              <p class="text-xs text-slate-600 mt-0.5">${a.reportedBy||''}</p>
            </div>
          </div>
          <span class="text-xs px-2 py-0.5 rounded-full border font-semibold flex-shrink-0 ${sc}">${a.status}</span>
        </div>
        ${!hasCoords?'<p class="text-xs text-slate-700 mt-1.5 italic">No GPS data</p>':''}
      </div>`;
    }).join('');
  }

  function filterMap(type){
    activeFilter = type;
    document.querySelectorAll('.map-pill').forEach(b=>b.classList.remove('active'));
    document.getElementById('btn-'+type).classList.add('active');
    renderMarkers(allAlerts); renderList(allAlerts);
  }
  // Set initial active
  document.getElementById('btn-all').classList.add('active');

  async function fetchAlerts(){
    try{
      const data = await fetch('/api/alerts').then(r=>r.json());
      allAlerts = data;
      renderMarkers(data); renderList(data);
      document.getElementById('statTotal').textContent   = data.length;
      document.getElementById('statFire').textContent    = data.filter(a=>a.type==='fire').length;
      document.getElementById('statCrime').textContent   = data.filter(a=>a.type==='crime').length;
      document.getElementById('statMedical').textContent = data.filter(a=>a.type==='medical').length;
      document.getElementById('mapUpdated').textContent  = 'Updated '+new Date().toLocaleTimeString();
    }catch(e){ console.error(e); }
  }

  fetchAlerts();
  setInterval(fetchAlerts, 10000);

  // Heatmap
  let heatLayer=null, heatVisible=false;
  function toggleHeatmap(){
    const btn = document.getElementById('btn-heat');
    if(heatVisible){ if(heatLayer) map.removeLayer(heatLayer); heatVisible=false; btn.classList.remove('active'); return; }
    const points = allAlerts.filter(a=>a.latitude&&a.longitude)
      .map(a=>[a.latitude,a.longitude,a.severity==='critical'?1:a.severity==='high'?.7:.4]);
    if(!points.length){ return; }
    const load = () => {
      heatLayer = L.heatLayer(points,{radius:35,blur:20,maxZoom:17,gradient:{0.4:'#3b82f6',0.6:'#f97316',1.0:'#ef4444'}}).addTo(map);
      heatVisible=true; btn.classList.add('active');
    };
    if(typeof L.heatLayer==='undefined'){
      const s=document.createElement('script'); s.src='https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js'; s.onload=load; document.head.appendChild(s);
    } else { load(); }
  }

  // Fly to location from query param
  const urlParams = new URLSearchParams(window.location.search);
  const flyLat = parseFloat(urlParams.get('lat'));
  const flyLng = parseFloat(urlParams.get('lng'));
  if(!isNaN(flyLat)&&!isNaN(flyLng)){
    setTimeout(()=>{
      map.setView([flyLat,flyLng],17);
      L.circleMarker([flyLat,flyLng],{radius:22,color:'#dc2626',fillColor:'#dc2626',fillOpacity:.15,weight:2}).addTo(map);
    },800);
  }

  // Sidebar
  function openSidebar(){ document.getElementById('sidebar').classList.add('open'); document.getElementById('sidebarOverlay').classList.add('open'); document.body.style.overflow='hidden'; }
  function closeSidebar(){ document.getElementById('sidebar').classList.remove('open'); document.getElementById('sidebarOverlay').classList.remove('open'); document.body.style.overflow=''; }

  (function(){
    var sb = document.getElementById('sidebar');
    if(!sb) return;
    sb.addEventListener('click', function(e){
      var link = e.target.closest('a[href]');
      if(!link) return;
      var href = link.getAttribute('href');
      if(href==='/logout') return;
      e.preventDefault();
      sb.classList.remove('open');
      document.getElementById('sidebarOverlay').classList.remove('open');
      document.body.style.overflow='';
      setTimeout(function(){ window.location.href=href; },200);
    });
  })();
</script>

</body>
</html>


