{{> head}}
<body class="bg-[#060b14] min-h-screen flex flex-col">
<div class="sidebar-overlay" id="sidebarOverlay" onclick="closeSidebar()"></div>

  <!-- Sidebar -->
  <aside class="sidebar-fixed w-64 bg-[#0a1628] border-r border-white/5 flex flex-col fixed h-full z-50 shadow-2xl" id="sidebar">
    <div class="px-5 py-5 border-b border-white/5">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-red-600 rounded-xl flex items-center justify-center pulse-ring shadow-lg shadow-red-900/40 flex-shrink-0"><svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg></div>
        <div><p class="text-sm font-black text-white leading-none tracking-tight">Emergency Hotline</p><p class="text-xs text-slate-500 mt-0.5">Alarm System</p></div>
      </div>
    </div>
    <nav class="flex-1 px-3 py-4 space-y-0.5">
      <a href="/user/dashboard" class="nav-item nav-active flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-sm font-semibold">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        Home
      </a>
      <a href="/alerts/history" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        My Reports
      </a>
      <a href="/map" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
        Live Map
      </a>
      <a href="/profile" class="nav-item flex items-center gap-3 px-3 py-2.5 rounded-r-xl text-slate-400 text-sm font-medium">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        My Profile
      </a>
    </nav>
    <div class="px-3 py-3 border-t border-white/5 flex-shrink-0" style="padding-bottom:max(60px,env(safe-area-inset-bottom))">
      <div class="flex items-center gap-2.5 px-2 py-2 mb-1 bg-white/3 rounded-xl">
        <div class="w-7 h-7 bg-white/10 rounded-full flex items-center justify-center flex-shrink-0"><span class="text-xs font-black text-slate-300">{{ userName.[0] }}</span></div>
        <div class="min-w-0 flex-1"><p class="text-xs font-bold text-white truncate leading-none">{{ userName }}</p><p class="text-xs text-slate-500 truncate mt-0.5">{{ userEmail }}</p></div>
      </div>
      <a href="/logout" class="nav-item flex items-center gap-2 px-2 py-2 rounded-xl text-slate-500 hover:text-red-400 hover:bg-red-950/20 text-sm transition">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
        Sign Out
      </a>
    </div>
  </aside>

  <!-- Main -->
  <div class="main-content ml-0 flex-1 flex flex-col min-h-screen w-full">

    <header class="bg-[#0a1628]/80 backdrop-blur-xl border-b border-white/5 px-4 lg:px-8 py-4 flex justify-between items-center sticky top-0 z-20">
      <div class="flex items-center gap-3">
        <button onclick="openSidebar()" style="width:36px;height:36px;min-width:36px;min-height:36px;max-width:36px;max-height:36px;display:flex;align-items:center;justify-content:center;flex-shrink:0;align-self:center;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);border-radius:12px;color:#94a3b8;cursor:pointer;padding:0;box-sizing:border-box" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#94a3b8'">
          <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <div>
          <h1 class="text-base lg:text-lg font-black text-white tracking-tight">Hi, {{ userName }} ??</h1>
          <p class="text-xs text-slate-500 mt-0.5 hidden sm:block">Tap an emergency button to report instantly</p>
        </div>
      </div>
      <div class="flex items-center gap-2">
        {{#if isAdmin}}
        <a href="/admin/dashboard" class="flex items-center gap-2 text-xs font-semibold text-slate-300 hover:text-white bg-white/5 hover:bg-white/10 border border-white/10 px-3 py-2 rounded-xl transition">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          Admin
        </a>
        {{/if}}
      </div>
    </header>

    <div class="flex-1 px-4 lg:px-8 py-5">

      {{#if success_msg}}
      <div class="mb-4 bg-green-950/50 border border-green-700/40 text-green-300 px-4 py-3 rounded-xl text-sm flex items-center gap-2 fade-in">? {{ success_msg }}</div>
      {{/if}}
      {{#if error_msg}}
      <div class="mb-4 bg-red-950/50 border border-red-700/40 text-red-300 px-4 py-3 rounded-xl text-sm flex items-center gap-2 fade-in">?? {{ error_msg }}</div>
      {{/if}}

      {{#if isSuspended}}
      <div class="mb-5 bg-red-950/60 border border-red-700/50 text-red-300 px-5 py-4 rounded-2xl flex items-start gap-3">
        <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
        <div><p class="font-bold text-white">Account Suspended</p><p class="text-sm mt-0.5">Your account has been suspended due to false emergency reports. Contact the administrator to restore access.</p></div>
      </div>
      {{else}}

      <!-- Cooldown warning -->
      {{#if cooldownRemaining}}
      <div class="mb-5 bg-yellow-950/40 border border-yellow-700/40 text-yellow-300 px-4 py-3 rounded-xl text-sm flex items-center gap-2">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Cooldown active � you can send another alert in <strong class="text-white ml-1" id="cdTimer">{{ cooldownRemaining }}s</strong>
      </div>
      {{/if}}

      {{#if falseReportCount}}
      <div class="mb-5 bg-yellow-950/30 border border-yellow-700/30 text-yellow-400 px-4 py-3 rounded-xl text-xs flex items-center gap-2">
        ?? You have <strong class="mx-1">{{ falseReportCount }}/3</strong> false report warning(s). Account suspended after 3.
      </div>
      {{/if}}

      <!-- MAIN EMERGENCY BUTTONS -->
      <div class="mb-6">
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-4 flex items-center gap-2">
          <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse inline-block"></span>
          Select Emergency Type
        </p>
        <form method="POST" action="/alerts/send" id="quickForm" enctype="multipart/form-data">
          <input type="hidden" name="latitude"  id="qlat">
          <input type="hidden" name="longitude" id="qlng">
          <input type="hidden" name="location"  id="qloc" value="Detecting location...">
          <input type="hidden" name="type"      id="qtype">
          <input type="hidden" name="severity"  value="high">
          <input type="file"   name="photo"     id="qFormPhoto" accept="image/*" class="hidden">

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

            <button type="button" onclick="quickAlert('fire')"
              class="btn-e rounded-2xl p-6 flex flex-col items-center justify-center gap-3 text-white font-bold min-h-[140px] transition"
              style="background:linear-gradient(135deg,#c2410c,#f97316);box-shadow:0 12px 40px rgba(249,115,22,.4)">
              <svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z"/></svg>
              <div class="text-center"><p class="text-lg font-black leading-none">FIRE</p><p class="text-xs opacity-75 mt-1">Bureau of Fire Protection</p></div>
            </button>

            <button type="button" onclick="quickAlert('crime')"
              class="btn-e rounded-2xl p-6 flex flex-col items-center justify-center gap-3 text-white font-bold min-h-[140px] transition"
              style="background:linear-gradient(135deg,#1e40af,#3b82f6);box-shadow:0 12px 40px rgba(59,130,246,.4)">
              <svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              <div class="text-center"><p class="text-lg font-black leading-none">POLICE</p><p class="text-xs opacity-75 mt-1">Philippine National Police</p></div>
            </button>

            <button type="button" onclick="quickAlert('medical')"
              class="btn-e rounded-2xl p-6 flex flex-col items-center justify-center gap-3 text-white font-bold min-h-[140px] transition"
              style="background:linear-gradient(135deg,#991b1b,#ef4444);box-shadow:0 12px 40px rgba(239,68,68,.4)">
              <svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
              <div class="text-center"><p class="text-lg font-black leading-none">MEDICAL</p><p class="text-xs opacity-75 mt-1">Emergency Medical Services</p></div>
            </button>

            <button type="button" onclick="quickAlert('all')"
              class="btn-e rounded-2xl p-6 flex flex-col items-center justify-center gap-3 text-white font-bold min-h-[140px] transition"
              style="background:linear-gradient(135deg,#1e293b,#475569);box-shadow:0 12px 40px rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15)">
              <svg class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              <div class="text-center"><p class="text-lg font-black leading-none">ALL AGENCIES</p><p class="text-xs opacity-75 mt-1">BFP + PNP + EMS</p></div>
            </button>

          </div>
        </form>
      </div>

      <!-- My recent reports -->
      {{#if myAlerts.length}}
      <div class="bg-[#0d1b2e] border border-white/5 rounded-2xl overflow-hidden">
        <div class="px-5 py-3.5 border-b border-white/5 flex justify-between items-center">
          <h2 class="text-sm font-bold text-white">My Recent Reports</h2>
          <a href="/alerts/history" class="text-xs text-red-400 hover:text-red-300 transition">View all ?</a>
        </div>
        <div class="divide-y divide-white/5">
          {{#each myAlerts}}
          <div class="px-5 py-3 flex items-center justify-between gap-3 hover:bg-white/3 transition">
            <div class="flex items-center gap-3">
              {{{ config.icon }}}
              <div>
                <p class="text-sm font-semibold text-white leading-none">{{ label }}</p>
                <p class="text-xs text-slate-600 mt-0.5">?? {{ location }} � {{ timeAgo }}</p>
              </div>
            </div>
            <span class="text-xs px-2 py-0.5 rounded-md font-semibold flex-shrink-0
              {{#if (eq status 'active')}}bg-red-500/15 text-red-400{{/if}}
              {{#if (eq status 'responding')}}bg-yellow-500/15 text-yellow-400{{/if}}
              {{#if (eq status 'resolved')}}bg-green-500/15 text-green-400{{/if}}">
              {{ status }}
            </span>
          </div>
          {{/each}}
        </div>
      </div>
      {{/if}}

      {{/if}}
    </div>

    {{> footer}}
  </div>

<!-- Confirm Modal -->
<div id="qModal" class="hidden fixed inset-0 bg-black/80 backdrop-blur-md flex items-center justify-center z-[9999] px-4">
  <div class="bg-[#0d1b2e] border border-white/10 rounded-3xl shadow-2xl w-full max-w-sm overflow-hidden fade-in">
    <div id="qModalMap" style="height:180px" class="w-full"></div>
    <div class="p-6 text-center">
      <div id="qModalIcon" class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-3"></div>
      <h3 class="text-xl font-black text-white mb-1" id="qModalTitle">Confirm Alert</h3>
      <p class="text-xs text-slate-500 mb-1" id="qModalLoc">
        <svg class="w-3 h-3 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <span id="qModalLocText">Detecting location...</span>
      </p>
      <!-- Manual location input (shown when GPS fails) -->
      <div id="qManualLocWrap" class="hidden mb-3">
        <input type="text" id="qManualLoc" placeholder="Enter your location manually..."
          class="w-full bg-white/5 border border-yellow-500/30 text-white placeholder-slate-600 rounded-xl px-3 py-2 text-xs focus:outline-none focus:border-yellow-400/50"/>
        <div class="flex items-center justify-between mt-1">
          <p class="text-xs text-yellow-500 flex items-center gap-1">
            <svg class="w-3 h-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            GPS unavailable — type your location
          </p>
          <button type="button" onclick="retryGPS()"
            class="text-xs text-blue-400 hover:text-blue-300 flex items-center gap-1 transition">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
            Retry GPS
          </button>
        </div>
      </div>
      <p class="text-xs text-slate-600 mb-4">Agency will be notified immediately.</p>

      <!-- Scam warning -->
      <div class="flex items-start gap-2.5 bg-yellow-950/40 border border-yellow-700/30 rounded-xl px-3 py-2.5 mb-4 text-left">
        <svg class="w-4 h-4 text-yellow-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <p class="text-xs text-yellow-300 leading-relaxed">
          <span class="font-bold text-yellow-200">False reports are prohibited.</span>
          Sending fake alerts may result in account suspension after 3 violations.
        </p>
      </div>

      <!-- Photo evidence upload -->
      <div class="mb-4">
        <label id="photoPickerLabel"
          class="flex items-center justify-center gap-2 w-full py-2.5 rounded-xl border border-dashed border-white/15 bg-white/4 hover:bg-white/8 cursor-pointer transition text-xs text-slate-400 hover:text-slate-200">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <span id="photoPickerText">Add Photo Evidence (optional)</span>
        </label>
        <input type="file" id="qPhotoInput" name="photo" accept="image/*" class="hidden"
          onchange="handlePhotoSelect(this)"/>
        <!-- Preview -->
        <div id="photoPreviewWrap" class="hidden mt-2 relative">
          <img id="photoPreview" src="" alt="Preview"
            class="w-full h-24 object-cover rounded-xl border border-white/10"/>
          <button type="button" onclick="clearPhoto()"
            class="absolute top-1.5 right-1.5 w-6 h-6 bg-black/70 hover:bg-black/90 rounded-full flex items-center justify-center text-white transition">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
      </div>

      <div class="flex gap-3">
        <button onclick="cancelQ()" class="flex-1 py-3 bg-white/5 hover:bg-white/10 border border-white/10 text-slate-300 rounded-xl font-semibold text-sm transition">Cancel</button>
        <button id="qSendBtn" onclick="sendQ()" class="flex-1 py-3 text-white rounded-xl font-black text-sm transition" style="background:#dc2626;box-shadow:0 8px 24px rgba(220,38,38,.4)">Send Alert</button>
      </div>
    </div>
  </div>
</div>

<script>
  let qType = null, qLat = null, qLng = null, qAddr = '';
  let qMapInst = null, qMarker = null;
  let gpsReady = false;
  const COLORS = { fire:'#f97316', crime:'#3b82f6', medical:'#ef4444', all:'#64748b' };
  const LABELS = { fire:'FIRE', crime:'POLICE', medical:'MEDICAL', all:'ALL AGENCIES' };

  // GPS detection with retry
  function detectGPS() {
    if (!navigator.geolocation) {
      showManualInput('GPS not supported on this device.');
      return;
    }
    navigator.geolocation.getCurrentPosition(
      async pos => {
        qLat = pos.coords.latitude;
        qLng = pos.coords.longitude;
        gpsReady = true;
        document.getElementById('qlat').value = qLat;
        document.getElementById('qlng').value = qLng;
        try {
          const d = await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${qLat}&lon=${qLng}&format=json`, { headers: { 'Accept-Language': 'en' } }).then(r => r.json());
          const a = d.address || {};
          qAddr = [a.road||a.pedestrian, a.suburb||a.village, a.city||a.town, a.state, a.country].filter(Boolean).join(', ') || d.display_name || `${qLat.toFixed(4)}, ${qLng.toFixed(4)}`;
        } catch {
          qAddr = `${qLat.toFixed(4)}, ${qLng.toFixed(4)}`;
        }
        document.getElementById('qloc').value = qAddr;
        // Update modal if open
        updateModalLoc();
        hideManualInput();
      },
      err => {
        const msgs = { 1: 'Location permission denied.', 2: 'Signal too weak — GPS unavailable.', 3: 'GPS timed out.' };
        showManualInput(msgs[err.code] || 'GPS unavailable.');
      },
      { enableHighAccuracy: true, timeout: 10000, maximumAge: 30000 }
    );
  }

  function showManualInput(reason) {
    document.getElementById('qManualLocWrap').classList.remove('hidden');
    document.getElementById('qModalLocText').textContent = reason || 'GPS unavailable';
    // Listen for manual input
    document.getElementById('qManualLoc').addEventListener('input', function() {
      qAddr = this.value;
      document.getElementById('qloc').value = qAddr;
      document.getElementById('qModalLocText').textContent = qAddr || 'Enter location above';
    });
  }

  function hideManualInput() {
    document.getElementById('qManualLocWrap').classList.add('hidden');
  }

  function updateModalLoc() {
    const el = document.getElementById('qModalLocText');
    if (el) el.textContent = qAddr || 'Location detected';
  }

  // Start GPS on load
  window.addEventListener('load', detectGPS);

  function retryGPS() {
    document.getElementById('qModalLocText').textContent = 'Retrying GPS...';
    detectGPS();
  }

  // Cooldown timer
  let cdSecs = {{ cooldownRemaining }};
  if (cdSecs > 0) {
    const el = document.getElementById('cdTimer');
    const t = setInterval(() => {
      cdSecs--;
      if (el) el.textContent = cdSecs + 's';
      if (cdSecs <= 0) { clearInterval(t); location.reload(); }
    }, 1000);
  }

  function quickAlert(type) {
    qType = type;
    const color = COLORS[type];
    const label = LABELS[type];
    document.getElementById('qModalTitle').textContent = label + ' ALERT';
    document.getElementById('qModalLocText').textContent = qAddr || 'Detecting location...';
    // Show manual input if GPS not ready
    if (!gpsReady) {
      document.getElementById('qManualLocWrap').classList.remove('hidden');
    }
    const iconEl = document.getElementById('qModalIcon');
    iconEl.style.background = color + '20';
    iconEl.style.border = '2px solid ' + color + '50';
    iconEl.innerHTML = `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="${color}" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>`;
    document.getElementById('qSendBtn').style.background = color;
    document.getElementById('qSendBtn').textContent = 'Send Alert';
    document.getElementById('qSendBtn').disabled = false;
    document.getElementById('qSendBtn').style.opacity = '1';
    document.getElementById('qModal').classList.remove('hidden');
    setTimeout(() => {
      if (!qMapInst) {
        qMapInst = L.map('qModalMap',{zoomControl:false,attributionControl:false,dragging:false,scrollWheelZoom:false});
        L.tileLayer('https://{s}.google.com/vt/lyrs=m&x={x}&y={y}&z={z}',{subdomains:['mt0','mt1','mt2','mt3'],maxZoom:20}).addTo(qMapInst);
      }
      if (qLat && qLng) {
        qMapInst.setView([qLat,qLng],15);
        if (qMarker) qMapInst.removeLayer(qMarker);
        qMarker = L.circleMarker([qLat,qLng],{radius:12,color:'#fff',fillColor:color,fillOpacity:1,weight:3}).addTo(qMapInst);
      } else { qMapInst.setView([12.8797,121.7740],6); }
      qMapInst.invalidateSize();
    }, 100);
  }

  function sendQ() {
    // Use manual location if GPS not available
    if (!gpsReady) {
      const manual = document.getElementById('qManualLoc')?.value?.trim();
      if (!manual) {
        document.getElementById('qManualLoc').style.borderColor = 'rgba(239,68,68,.6)';
        document.getElementById('qManualLoc').placeholder = 'Please enter your location first!';
        return;
      }
      document.getElementById('qloc').value = manual;
    }
    document.getElementById('qModal').classList.add('hidden');
    document.getElementById('qtype').value = qType;
    var modalFile = document.getElementById('qPhotoInput');
    if (modalFile.files && modalFile.files[0]) {
      var dt = new DataTransfer();
      dt.items.add(modalFile.files[0]);
      var formPhoto = document.querySelector('#quickForm input[name="photo"]');
      if (formPhoto) formPhoto.files = dt.files;
    }
    document.getElementById('quickForm').submit();
  }

  function cancelQ() {
    document.getElementById('qModal').classList.add('hidden');
    const btn = document.getElementById('qSendBtn');
    btn.disabled = false; btn.style.opacity = '1'; btn.textContent = 'Send Alert';
    clearPhoto();
    // Reset manual location
    const manualInput = document.getElementById('qManualLoc');
    if (manualInput) { manualInput.value = ''; manualInput.style.borderColor = ''; }
    document.getElementById('qManualLocWrap').classList.add('hidden');
    qType = null;
  }

  // Photo evidence helpers
  document.getElementById('photoPickerLabel').addEventListener('click', function() {
    document.getElementById('qPhotoInput').click();
  });

  function handlePhotoSelect(input) {
    if (!input.files || !input.files[0]) return;
    var file = input.files[0];
    var reader = new FileReader();
    reader.onload = function(e) {
      document.getElementById('photoPreview').src = e.target.result;
      document.getElementById('photoPreviewWrap').classList.remove('hidden');
      document.getElementById('photoPickerText').textContent = '?? ' + file.name;
    };
    reader.readAsDataURL(file);
  }

  function clearPhoto() {
    document.getElementById('qPhotoInput').value = '';
    document.getElementById('photoPreview').src = '';
    document.getElementById('photoPreviewWrap').classList.add('hidden');
    document.getElementById('photoPickerText').textContent = 'Add Photo Evidence (optional)';
  }

  function openSidebar(){ document.getElementById('sidebar').classList.add('open'); document.getElementById('sidebarOverlay').classList.add('open'); document.body.style.overflow='hidden'; }
  function closeSidebar(){ document.getElementById('sidebar').classList.remove('open'); document.getElementById('sidebarOverlay').classList.remove('open'); document.body.style.overflow=''; }
  function navTo(e, url){ e.preventDefault(); closeSidebar(); setTimeout(()=>{ window.location.href=url; }, 220); }

  // Attach sidebar link interceptor directly � script is at bottom so DOM is ready
  (function() {
    var sb = document.getElementById('sidebar');
    if (!sb) return;
    sb.addEventListener('click', function(e) {
      var link = e.target.closest('a[href]');
      if (!link) return;
      var href = link.getAttribute('href');
      if (href === '/logout') return;
      e.preventDefault();
      sb.classList.remove('open');
      document.getElementById('sidebarOverlay').classList.remove('open');
      document.body.style.overflow = '';
      setTimeout(function() { window.location.href = href; }, 200);
    });
  })();

  // Auto-trigger alert if redirected from home page
  window.addEventListener('load', () => {
    const alertType = new URLSearchParams(window.location.search).get('alert');
    if (alertType && typeof quickAlert === 'function') {
      setTimeout(() => quickAlert(alertType), 600);
    }
  });

  // ── Real-time report status polling ──────────────────────
  // Track last known statuses of user's own reports
  const reportStatuses = {};
  {{#each myAlerts}}
  reportStatuses[{{id}}] = '{{ status }}';
  {{/each}}

  async function pollMyReports() {
    try {
      const res = await fetch('/api/my-alerts');
      if (!res.ok) return;
      const alerts = await res.json();

      alerts.forEach(a => {
        const prev = reportStatuses[a.id];
        if (prev && prev !== a.status) {
          // Status changed — notify user
          showStatusBanner(a, prev, a.status);
          reportStatuses[a.id] = a.status;
          // Browser notification
          if (Notification.permission === 'granted') {
            const msgs = {
              responding: `Agency is responding to your ${a.label} report!`,
              resolved:   `Your ${a.label} report has been resolved.`
            };
            if (msgs[a.status]) {
              new Notification('Emergency Hotline Update', {
                body: msgs[a.status],
                icon: '/icons/icon-192.png',
                tag: 'report-update-' + a.id
              });
            }
          }
        }
        if (!reportStatuses[a.id]) reportStatuses[a.id] = a.status;
      });
    } catch(e) {}
  }

  function showStatusBanner(alert, oldStatus, newStatus) {
    // Remove existing banner
    const existing = document.getElementById('statusUpdateBanner');
    if (existing) existing.remove();

    const isResolved   = newStatus === 'resolved';
    const isResponding = newStatus === 'responding';
    const color  = isResolved ? '#4ade80' : '#fbbf24';
    const bg     = isResolved ? 'rgba(34,197,94,.12)' : 'rgba(234,179,8,.12)';
    const border = isResolved ? 'rgba(34,197,94,.3)'  : 'rgba(234,179,8,.3)';
    const icon   = isResolved
      ? '<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#4ade80" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>'
      : '<svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="#fbbf24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>';
    const msg = isResolved
      ? `Your <strong>${alert.label}</strong> report has been <strong>resolved</strong>.`
      : `An agency is now <strong>responding</strong> to your <strong>${alert.label}</strong> report.`;

    const banner = document.createElement('div');
    banner.id = 'statusUpdateBanner';
    banner.style.cssText = `position:fixed;top:72px;left:50%;transform:translateX(-50%);z-index:9999;width:100%;max-width:400px;padding:0 16px`;
    banner.innerHTML = `
      <div style="background:#0d1b2e;border:1px solid ${border};border-radius:16px;padding:14px 16px;box-shadow:0 8px 40px rgba(0,0,0,.8),0 0 24px ${color}20;display:flex;align-items:center;gap:12px;animation:fi .3s ease">
        <div style="width:40px;height:40px;border-radius:12px;background:${bg};border:1px solid ${border};display:flex;align-items:center;justify-content:center;flex-shrink:0">${icon}</div>
        <div style="flex:1;min-width:0">
          <p style="font-size:13px;font-weight:800;color:#f1f5f9;margin:0">${isResolved ? 'Report Resolved' : 'Agency Responding'}</p>
          <p style="font-size:11px;color:#64748b;margin:3px 0 0">${msg}</p>
        </div>
        <button onclick="this.parentElement.parentElement.remove()" style="background:none;border:none;cursor:pointer;color:#475569;padding:4px;flex-shrink:0">
          <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>`;
    document.body.appendChild(banner);

    // Play a gentle notification sound
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      const notes = isResolved ? [523, 659, 784] : [440, 554];
      notes.forEach((freq, i) => {
        const osc = ctx.createOscillator(); const gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.type = 'sine'; osc.frequency.value = freq;
        const t = ctx.currentTime + i * 0.18;
        gain.gain.setValueAtTime(0.4, t);
        gain.gain.exponentialRampToValueAtTime(0.001, t + 0.15);
        osc.start(t); osc.stop(t + 0.18);
      });
    } catch(e) {}

    // Auto-remove after 10s
    setTimeout(() => { if (banner.parentElement) banner.remove(); }, 10000);
  }

  // Request notification permission
  if (Notification.permission === 'default') Notification.requestPermission();

  // Poll every 15 seconds
  setInterval(pollMyReports, 15000);
</script>

